//@version=6
indicator("Gecko Smart Money Indicator v1", overlay = true, max_boxes_count = 200, max_lines_count = 200, max_labels_count = 200)

// Gecko SMI Pine v1 is a standalone current-chart-timeframe overlay.
// It is context-only: no entries, no sizing, no orders, no execution.

// Inputs
displayMode = input.string("Clean", "Display mode", options = ["Clean", "Normal", "Debug"])
swingLen = input.int(3, "Swing length", minval = 1)
showStructure = input.bool(true, "Show Structure")
showSwingLabels = input.bool(true, "Show HH / HL / LH / LL")
showFvg = input.bool(true, "Show FVG")
showOb = input.bool(true, "Show Order Blocks")
showLiquidity = input.bool(true, "Show Liquidity Pools")
showSweeps = input.bool(true, "Show Liquidity Sweeps")
showMidpoints = input.bool(true, "Show Midpoints / CE")
showInvalidatedZones = input.bool(false, "Show Invalidated Zones")
showZoneStatusLabels = input.bool(false, "Show zone status labels")
showContextBadge = input.bool(true, "Show current context badge")

maxFvgZones = input.int(30, "Max FVG zones", minval = 1, maxval = 100)
maxObZones = input.int(20, "Max OB zones", minval = 1, maxval = 80)
maxLiquidityLevels = input.int(30, "Max liquidity levels", minval = 1, maxval = 100)
maxLabels = input.int(80, "Max labels", minval = 10, maxval = 200)

useAtrFilter = input.bool(true, "Use ATR filter")
atrLen = input.int(14, "ATR length", minval = 1)
minFvgAtr = input.float(0.15, "Min FVG size as ATR", minval = 0.0, step = 0.05)
requireImpulseCandle = input.bool(true, "Require impulse candle for FVG")
minObDisplacementAtr = input.float(0.25, "Min OB displacement as ATR", minval = 0.0, step = 0.05)
obLookback = input.int(5, "OB origin lookback", minval = 1, maxval = 20)
reactionMaxBars = input.int(5, "Reaction max bars after touch", minval = 1, maxval = 50)
reactionMode = input.string("Close beyond midpoint", "Reaction mode", options = ["Close beyond midpoint", "Close outside zone"])
liquidityLineMode = input.string("Active", "Liquidity line mode", options = ["Active", "Historical"])

atr = ta.atr(atrLen)
confirmedBar = barstate.isconfirmed
isClean = displayMode == "Clean"
isNormal = displayMode == "Normal"
isDebug = displayMode == "Debug"
effectiveShowSwingLabels = isDebug ? showSwingLabels : isNormal ? showSwingLabels : false
effectiveShowInvalidated = isDebug ? showInvalidatedZones : isNormal ? showInvalidatedZones : false
effectiveShowZoneStatusLabels = isDebug ? showZoneStatusLabels : false
effectiveShowStructure = isDebug ? showStructure : isNormal ? showStructure : false
effectiveReactionMode = isClean ? "Close outside zone" : reactionMode
effectiveShowContextBadge = showContextBadge

type SmiZone
    box rect
    line midLine
    label tag
    float low
    float high
    float mid
    bool bull
    bool invalidated
    bool touched
    bool midpointTouched
    bool reacted
    string kind
    int createdBar
    int lastTouchedBar

var SmiZone[] fvgZones = array.new<SmiZone>()
var SmiZone[] obZones = array.new<SmiZone>()
var line[] liquidityLines = array.new_line()
var label[] chartLabels = array.new_label()

var float lastSwingHigh = na
var float lastSwingLow = na
var int lastSwingHighBar = na
var int lastSwingLowBar = na
var float previousSwingHigh = na
var float previousSwingLow = na
var bool highBroken = false
var bool lowBroken = false
var bool lastHighSwept = false
var bool lastLowSwept = false
var int lastBullObOriginBar = na
var int lastBearObOriginBar = na
var int structureBias = 0

f_deleteZone(SmiZone z) =>
    box.delete(z.rect)
    if not na(z.midLine)
        line.delete(z.midLine)
    if not na(z.tag)
        label.delete(z.tag)

f_trimLabels() =>
    while array.size(chartLabels) > maxLabels
        oldLabel = array.shift(chartLabels)
        label.delete(oldLabel)

f_addLabel(x, y, labelText, bg, textColor, style) =>
    newLabel = label.new(x = x, y = y, text = labelText, style = style, color = bg, textcolor = textColor, size = size.tiny)
    array.push(chartLabels, newLabel)
    f_trimLabels()
    newLabel

f_addLiquidityLine(float level, bool buySide, int x) =>
    if showLiquidity
        levelLine = line.new(x1 = x, y1 = level, x2 = bar_index, y2 = level, color = color.new(buySide ? color.red : color.green, 35), style = line.style_dashed)
        array.push(liquidityLines, levelLine)
        while array.size(liquidityLines) > maxLiquidityLevels
            oldLine = array.shift(liquidityLines)
            line.delete(oldLine)

f_updateLiquidityLines() =>
    if showLiquidity and liquidityLineMode == "Active" and array.size(liquidityLines) > 0
        for i = 0 to array.size(liquidityLines) - 1
            liquidityLine = array.get(liquidityLines, i)
            line.set_x2(liquidityLine, bar_index)

f_trimZones(SmiZone[] zones, int maxCount) =>
    while array.size(zones) > maxCount
        oldZone = array.shift(zones)
        f_deleteZone(oldZone)

f_addZone(SmiZone[] zones, int maxCount, string kind, bool bull, int leftBar, float zoneLow, float zoneHigh) =>
    zoneColor = bull ? color.green : color.red
    zoneBox = box.new(left = leftBar, top = zoneHigh, right = bar_index, bottom = zoneLow, bgcolor = color.new(zoneColor, 86), border_color = color.new(zoneColor, 35))
    midpoint = (zoneLow + zoneHigh) / 2.0
    midpointLine = showMidpoints ? line.new(x1 = leftBar, y1 = midpoint, x2 = bar_index, y2 = midpoint, color = color.new(color.gray, 35), style = line.style_dotted) : na
    zoneLabel = effectiveShowZoneStatusLabels ? label.new(x = bar_index, y = zoneHigh, text = kind + " PINE_CONTEXT_ONLY", style = label.style_label_left, color = color.new(zoneColor, 70), textcolor = color.white, size = size.tiny) : na
    zone = SmiZone.new(zoneBox, midpointLine, zoneLabel, zoneLow, zoneHigh, midpoint, bull, false, false, false, false, kind, bar_index, na)
    array.push(zones, zone)
    f_trimZones(zones, maxCount)

f_updateZones(SmiZone[] zones) =>
    midpointTouchedNow = false
    invalidatedNow = false
    reactionNow = false
    if array.size(zones) > 0
        zoneCount = array.size(zones)
        for step = 0 to zoneCount - 1
            i = zoneCount - 1 - step
            zone = array.get(zones, i)
            box.set_right(zone.rect, bar_index)
            if not na(zone.midLine)
                line.set_x2(zone.midLine, bar_index)
            if not na(zone.tag)
                label.set_x(zone.tag, bar_index)

            eligibleForLifecycle = bar_index > zone.createdBar
            touchedNow = eligibleForLifecycle and confirmedBar and not zone.invalidated and high >= zone.low and low <= zone.high
            midNow = touchedNow and high >= zone.mid and low <= zone.mid
            touchBarForReaction = touchedNow ? bar_index : zone.lastTouchedBar
            recentTouch = not na(touchBarForReaction) and bar_index - touchBarForReaction <= reactionMaxBars
            bullReactionMidpoint = recentTouch and close > zone.mid and close > open and close > zone.low
            bearReactionMidpoint = recentTouch and close < zone.mid and close < open and close < zone.high
            bullReactionOutside = recentTouch and close > zone.high and close > open
            bearReactionOutside = recentTouch and close < zone.low and close < open
            bullReaction = effectiveReactionMode == "Close outside zone" ? bullReactionOutside : bullReactionMidpoint
            bearReaction = effectiveReactionMode == "Close outside zone" ? bearReactionOutside : bearReactionMidpoint
            invalidNow = eligibleForLifecycle and confirmedBar and not zone.invalidated and (zone.bull ? close < zone.low : close > zone.high)
            reactedNow = eligibleForLifecycle and confirmedBar and not zone.invalidated and not zone.reacted and (zone.bull ? bullReaction : bearReaction)

            if touchedNow
                zone.touched := true
                zone.lastTouchedBar := bar_index
            if midNow
                zone.midpointTouched := true
                midpointTouchedNow := true
            if reactedNow
                zone.reacted := true
                reactionNow := true
                if not na(zone.tag)
                    label.set_text(zone.tag, zone.kind + " PINE_REACTION_CONFIRMED")
            if invalidNow
                zone.invalidated := true
                invalidatedNow := true
                if effectiveShowInvalidated
                    box.set_bgcolor(zone.rect, color.new(color.gray, 88))
                    box.set_border_color(zone.rect, color.new(color.gray, 45))
                    if not na(zone.midLine)
                        line.set_color(zone.midLine, color.new(color.gray, 55))
                    if not na(zone.tag)
                        label.set_text(zone.tag, zone.kind + " PINE_INVALIDATED")
                        label.set_color(zone.tag, color.new(color.gray, 60))
                else
                    f_deleteZone(zone)
                    array.remove(zones, i)
            if not invalidNow or effectiveShowInvalidated
                array.set(zones, i, zone)
    [midpointTouchedNow, invalidatedNow, reactionNow]

f_findBullObOffset(int maxBack) =>
    int found = na
    for i = 1 to maxBack
        if na(found) and close[i] < open[i]
            found := i
    found

f_findBearObOffset(int maxBack) =>
    int found = na
    for i = 1 to maxBack
        if na(found) and close[i] > open[i]
            found := i
    found

// Swing structure
ph = ta.pivothigh(high, swingLen, swingLen)
pl = ta.pivotlow(low, swingLen, swingLen)

if confirmedBar and not na(ph)
    previousSwingHigh := lastSwingHigh
    lastSwingHigh := ph
    lastSwingHighBar := bar_index - swingLen
    highBroken := false
    lastHighSwept := false
    f_addLiquidityLine(lastSwingHigh, true, lastSwingHighBar)
    if effectiveShowSwingLabels
        swingText = not na(previousSwingHigh) and lastSwingHigh > previousSwingHigh ? "HH" : "LH"
        f_addLabel(lastSwingHighBar, lastSwingHigh, swingText, color.new(color.red, 65), color.white, label.style_label_down)

if confirmedBar and not na(pl)
    previousSwingLow := lastSwingLow
    lastSwingLow := pl
    lastSwingLowBar := bar_index - swingLen
    lowBroken := false
    lastLowSwept := false
    f_addLiquidityLine(lastSwingLow, false, lastSwingLowBar)
    if effectiveShowSwingLabels
        swingText = not na(previousSwingLow) and lastSwingLow > previousSwingLow ? "HL" : "LL"
        f_addLabel(lastSwingLowBar, lastSwingLow, swingText, color.new(color.green, 65), color.white, label.style_label_up)

bosBull = confirmedBar and not na(lastSwingHigh) and not highBroken and close > lastSwingHigh
bosBear = confirmedBar and not na(lastSwingLow) and not lowBroken and close < lastSwingLow
chochBull = bosBull and structureBias < 0
chochBear = bosBear and structureBias > 0

if bosBull
    highBroken := true
    structureBias := 1
    if effectiveShowStructure
        f_addLabel(bar_index, high, chochBull ? "CHoCH up" : "BOS up", color.new(color.green, 45), color.white, label.style_label_up)

if bosBear
    lowBroken := true
    structureBias := -1
    if effectiveShowStructure
        f_addLabel(bar_index, low, chochBear ? "CHoCH down" : "BOS down", color.new(color.red, 45), color.white, label.style_label_down)

// FVG detection
bullFvgGap = bar_index >= 2 ? low - high[2] : na
bearFvgGap = bar_index >= 2 ? low[2] - high : na
bullImpulse = bar_index >= 2 and close[1] > open[1]
bearImpulse = bar_index >= 2 and close[1] < open[1]
bullFvg = confirmedBar and showFvg and bar_index >= 2 and high[2] < low and (not requireImpulseCandle or bullImpulse) and (not useAtrFilter or bullFvgGap >= atr * minFvgAtr)
bearFvg = confirmedBar and showFvg and bar_index >= 2 and low[2] > high and (not requireImpulseCandle or bearImpulse) and (not useAtrFilter or bearFvgGap >= atr * minFvgAtr)

if bullFvg
    f_addZone(fvgZones, maxFvgZones, "FVG", true, bar_index - 2, high[2], low)

if bearFvg
    f_addZone(fvgZones, maxFvgZones, "FVG", false, bar_index - 2, high, low[2])

// Order block detection
bullObOffset = bosBull and math.abs(close - open) >= atr * minObDisplacementAtr ? f_findBullObOffset(obLookback) : na
bearObOffset = bosBear and math.abs(close - open) >= atr * minObDisplacementAtr ? f_findBearObOffset(obLookback) : na

if showOb and not na(bullObOffset)
    obLow = low[bullObOffset]
    obHigh = high[bullObOffset]
    bullOriginBar = bar_index - bullObOffset
    if bullOriginBar != lastBullObOriginBar
        f_addZone(obZones, maxObZones, "OB", true, bullOriginBar, obLow, obHigh)
        lastBullObOriginBar := bullOriginBar

if showOb and not na(bearObOffset)
    obLow = low[bearObOffset]
    obHigh = high[bearObOffset]
    bearOriginBar = bar_index - bearObOffset
    if bearOriginBar != lastBearObOriginBar
        f_addZone(obZones, maxObZones, "OB", false, bearOriginBar, obLow, obHigh)
        lastBearObOriginBar := bearOriginBar

// Liquidity sweeps
sellSideSweep = confirmedBar and showSweeps and not na(lastSwingLow) and not lastLowSwept and low < lastSwingLow and close > lastSwingLow
buySideSweep = confirmedBar and showSweeps and not na(lastSwingHigh) and not lastHighSwept and high > lastSwingHigh and close < lastSwingHigh

if sellSideSweep
    lastLowSwept := true

if buySideSweep
    lastHighSwept := true

plotshape(sellSideSweep, title = "SMI Sell-side Sweep", style = shape.triangleup, location = location.belowbar, text = "SSL", color = color.new(color.green, 0), textcolor = color.white, size = size.tiny)
plotshape(buySideSweep, title = "SMI Buy-side Sweep", style = shape.triangledown, location = location.abovebar, text = "BSL", color = color.new(color.red, 0), textcolor = color.white, size = size.tiny)

// Zone lifecycle
f_updateLiquidityLines()
[fvgMidpointTouched, fvgInvalidated, fvgReaction] = f_updateZones(fvgZones)
[obMidpointTouched, obInvalidated, obReaction] = f_updateZones(obZones)

// Context quality marker
contextScore = 0
contextScore += structureBias != 0 ? 20 : 0
contextScore += bullFvg or bearFvg ? 20 : 0
contextScore += not na(bullObOffset) or not na(bearObOffset) ? 20 : 0
contextScore += sellSideSweep or buySideSweep ? 20 : 0
contextScore += fvgReaction or obReaction ? 20 : 0

var label qualityLabel = na
if confirmedBar and effectiveShowContextBadge and barstate.islast
    qualityText = contextScore >= 80 ? "PINE_REACTION_CONFIRMED" : contextScore >= 50 ? "PINE_WATCHABLE" : contextScore >= 30 ? "PINE_WAIT_FOR_REACTION" : "PINE_CONTEXT_ONLY"
    if na(qualityLabel)
        qualityLabel := label.new(x = bar_index, y = high, text = "Current Context " + str.tostring(contextScore) + " " + qualityText, style = label.style_label_left, color = color.new(color.blue, 60), textcolor = color.white, size = size.small)
    else
        label.set_x(qualityLabel, bar_index)
        label.set_y(qualityLabel, high)
        label.set_text(qualityLabel, "Current Context " + str.tostring(contextScore) + " " + qualityText)

// Context alerts
alertcondition(bullFvg, "SMI Bullish FVG detected", "SMI Bullish FVG detected on current chart timeframe")
alertcondition(bearFvg, "SMI Bearish FVG detected", "SMI Bearish FVG detected on current chart timeframe")
alertcondition(sellSideSweep, "SMI Sell-side Sweep", "SMI Sell-side Sweep on current chart timeframe")
alertcondition(buySideSweep, "SMI Buy-side Sweep", "SMI Buy-side Sweep on current chart timeframe")
alertcondition(fvgMidpointTouched, "SMI FVG midpoint touched", "SMI FVG midpoint touched on current chart timeframe")
alertcondition(obMidpointTouched, "SMI OB touched", "SMI Order Block touched on current chart timeframe")
alertcondition(fvgReaction or obReaction, "SMI Reaction confirmed", "SMI Reaction confirmed on current chart timeframe")
alertcondition(fvgInvalidated or obInvalidated, "SMI Zone invalidated", "SMI Zone invalidated on current chart timeframe")
