{
  "name": "smart-money-indicator",
  "version": "0.2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./core/dist/index.js",
  "types": "./core/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./core/dist/index.d.ts",
      "import": "./core/dist/index.js"
    },
    "./config": {
      "types": "./core/dist/v2/smc-config.d.ts",
      "import": "./core/dist/v2/smc-config.js"
    },
    "./profiles": {
      "types": "./core/dist/v2/smc-config.d.ts",
      "import": "./core/dist/v2/smc-config.js"
    },
    "./types": {
      "types": "./core/dist/v2/smc-core.types.d.ts",
      "import": "./core/dist/v2/smc-core.types.js"
    },
    "./testing": {
      "types": "./core/dist/index.d.ts",
      "import": "./core/dist/index.js"
    }
  },
  "files": [
    "core/dist"
  ],
  "workspaces": [
    "core"
  ],
  "scripts": {
    "build": "tsc -p core/tsconfig.build.json",
    "prepare": "npm run build",
    "smoke:exports": "npm run build && node ./scripts/smoke-package-exports.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "check:pine-boundary": "rg -n \"request\\.security\\(|request\\.security_lower_tf\\(|request\\.seed\\(|\\bhttp\\b|\\bfetch\\b|strategy\\(|strategy\\.entry|strategy\\.order|strategy\\.exit|strategy\\.close|BUY NOW|SELL NOW|ENTER LONG|ENTER SHORT|/smi/|/debug/\" tradingview/pine --glob '*.pine' && exit 1 || exit 0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
